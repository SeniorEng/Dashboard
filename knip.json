{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "tests/**/*.test.ts",
    "server/scripts/**/*.ts",
    "client/src/features/*/hooks/index.ts"
  ],
  "project": [
    "client/src/**/*.{ts,tsx}",
    "server/**/*.ts",
    "shared/**/*.ts"
  ],
  "ignore": [
    "client/src/components/ui/**",
    "server/replit_integrations/**"
  ],
  "ignoreDependencies": [
    "tailwindcss",
    "node-zugferd",
    "tw-animate-css"
  ]
}
